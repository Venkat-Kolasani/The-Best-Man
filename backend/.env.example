# ─────────────────────────────────────────────
# Required: LLM provider (used by Cognee internally)
# ─────────────────────────────────────────────
# Free Gemini option (no credit card needed):
#   1. Go to https://aistudio.google.com/apikey
#   2. Create a free API key
#   3. Set:
#        LLM_API_KEY="<your-gemini-api-key>"
#
# OpenAI (requires billing):
#   Get key at https://platform.openai.com/api-keys
#   Set:
#        LLM_API_KEY="<your-openai-api-key>"
#        LLM_PROVIDER="openai"
#        LLM_MODEL="gpt-4o"
#
# Anthropic:
#   Get key at https://console.anthropic.com/
#   Set:
#        LLM_API_KEY="<your-anthropic-api-key>"
#        LLM_PROVIDER="anthropic"
#        LLM_MODEL="claude-sonnet-4-20250514"
#
# NOTE: You do NOT need to set LLM_PROVIDER or LLM_MODEL for Gemini —
#       the app defaults to provider="gemini" model="gemini/gemini-3.1-flash-lite".
#       Only set these if you want to override the defaults.
LLM_API_KEY="CHANGE_ME_YOUR_LLM_API_KEY"

# ─────────────────────────────────────────────
# Required for git-ingestion features
# ─────────────────────────────────────────────
# GitHub personal access token (classic or fine-grained).
# Scopes needed: repo (private repos) or public_repo (public only).
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN="CHANGE_ME_YOUR_GITHUB_TOKEN"

# ─────────────────────────────────────────────
# Cognee local storage
# ─────────────────────────────────────────────
# Where Cognee stores its SQLite/LanceDB graph data.
# Relative paths are relative to wherever you run the app.
COGNEE_DB_PATH="data/cognee"

# ─────────────────────────────────────────────
# Optional: Cognee runtime flags
# ─────────────────────────────────────────────
# Cognee 1.2+ enables multi-user access control by default.
# Set to "false" during local development to skip auth:
ENABLE_BACKEND_ACCESS_CONTROL="false"
#
# Session memory is enabled by default (CACHING=true).
# Set to "false" to store everything in the permanent graph:
# CACHING="false"
#
# Cognee 1.2.2 enables subprocess mode for both Kuzu (graph) and LanceDB
# (vector) by default, which requires ``cognee-db-workers``.  The subprocess
# init fails on macOS, so disable both to run in-process:
GRAPH_DATABASE_SUBPROCESS_ENABLED="false"
VECTOR_DB_SUBPROCESS_ENABLED="false"
