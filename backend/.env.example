# LLM provider key (OpenAI, Anthropic, etc.)
LLM_API_KEY="sk-placeholder"

# GitHub personal access token for repo ingestion
GITHUB_TOKEN="ghp_placeholder"

# Path where Cognee stores its graph data locally
COGNEE_DB_PATH="data/cognee"

# LLM provider and model Cognee should use
COGNEE_LLM_PROVIDER="openai"
COGNEE_LLM_MODEL="gpt-4o"
